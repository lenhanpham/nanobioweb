---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Steps from '~/components/widgets/Steps.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Our Science | Hoang Nhan NanoBiotech',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="The Platform"
    title="Driven by Nanobiotechnology"
    subtitle="We are pioneers in transforming agricultural byproducts and natural resources into cutting-edge green nano biomaterials. Our mission is to revolutionize plant health and protection."
    image={{
      src: '~/assets/images/bypro-lab-plants.png',
      alt: 'By-products lab plants',
      class: 'mx-auto rounded-md max-w-sm',
      width: 1024,
      height: 416,
    }}
  />

  <!-- Steps Widget (The Extraction Process) ****************** -->

  <Steps
    title="The Waste-to-Resource Extraction Process"
    subtitle="By repurposing materials like sugarcane bagasse, rice husk, and seaweed into advanced nanoparticles, we create products that enhance plant immunity and defend against diseases, pests, and fungi."
    items={[
      {
        title: 'Sourcing Specific By-Products',
        description:
          'We collect abundant agricultural waste such as sugarcane bagasse and rice husk, along with natural resources like seaweed.',
        icon: 'tabler:leaf',
      },
      {
        title: 'Green Refining & Processing',
        description:
          'Using environmentally friendly chemistry, we break down these raw materials without relying on harsh, toxic solvents.',
        icon: 'tabler:flask-2',
      },
      {
        title: 'Nanobiomaterial Engineering',
        description:
          'These materials are engineered at the nanoscale to deliver targeted benefits for plant health, penetrating the cuticle far more efficiently than standard applications.',
        icon: 'tabler:microscope',
      },
      {
        title: 'Formulating Custom Solutions',
        description:
          'From lab-scale research to scalable production, the final product is formulated into stable active nano powders or liquids, ready for greenhouses and large-scale farming operations.',
        icon: 'tabler:tractor',
      },
    ]}
    image={{
      src: '~/assets/images/production-process.png',
      alt: 'Production process',
    }}
    classes={{ image: 'max-h-96 md:max-h-[480px]' }}
  />

  <!-- Features2 Widget (The 6 Nano-Advantages) ************** -->

  <Features2
    title="Engineered at the Nanoscale"
    subtitle="From molecular engineering to field application — the scientific principles that make our nano-biomaterials uniquely effective."
    columns={3}
    items={[
      {
        title: 'Advanced Nano-Synthesis',
        description:
          'We conduct cutting-edge research to transform agricultural waste into high-value green nano-biomaterials, unlocking performance that conventional chemistry simply cannot achieve.',
        icon: 'tabler:atom',
      },
      {
        title: 'Precision Bio-Carriers',
        description:
          'Our state-of-the-art bio-based nano-carriers ensure systemic uptake and controlled release, delivering nutrients and crop protection precisely when and where crops need them — minimising waste and maximising efficacy.',
        icon: 'tabler:target-arrow',
      },
      {
        title: 'True Circular Economy',
        description:
          'Our sophisticated synthesis process generates zero hazardous waste. Every natural raw material — from rice husk to seaweed — is fully repurposed into next-generation fertilisers and bio-nano formulations.',
        icon: 'tabler:recycle',
      },
      {
        title: 'Enhanced Immunity & Growth',
        description:
          'Our highly engineered solutions actively stimulate robust root development, strengthen plant cell walls, and fortify natural resistance against drought, salinity, and extreme temperature fluctuations.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Targeted Pathogen Suppression',
        description:
          'Highly effective at naturally suppressing devastating plant pathogenic fungi and oomycetes — including <em>Pythium</em>, <em>Phytophthora</em>, <em>Fusarium</em>, and <em>Rhizoctonia</em> — reducing chemical fungicide dependency at the field scale.',
        icon: 'tabler:bug-off',
      },
      {
        title: 'From Lab to Field',
        description:
          'From milligram-scale synthesis to commercial-volume production, our formulations are proven in Australian field conditions and adaptable to foliar spray, fertigation, and seed treatment systems.',
        icon: 'tabler:tractor',
      },
    ]}
  />
</Layout>
