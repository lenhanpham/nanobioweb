---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Image from '~/components/common/Image.astro';
import Button from '~/components/ui/Button.astro';
import { getCollection } from 'astro:content';
import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'Hoang Nhan NanoBiotech | Revolutionising Crop Yields',
  ignoreTitleTemplate: true,
};

const products = await getCollection('product');
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Explore Products',
        href: '/products',
        icon: 'tabler:flask',
      },
      { text: 'Discover Our Science', href: '/our-science' },
    ]}
    image={{
      src: '~/assets/images/bypro-plant-fruit.png',
      alt: 'The cycle from agricultural by-products to advanced green nano-biomaterials',
      width: 783,
      height: 418,
      class: 'mx-auto rounded-md max-w-sm',
    }}
  >
    <Fragment slot="title">
      Revolutionising Crop Yields <br class="hidden md:inline" />
      &nbsp;
      <span class="text-primary dark:text-white highlight">through Circular Nanobiotech</span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="hidden sm:inline">
        From Australian agricultural waste to next-generation crop protection. We engineer green nano-biomaterials that
        boost yields, fight disease, and close the loop on farm waste.
      </span>
    </Fragment>
  </Hero>

  <!-- Content Widget (Problem / Solution — slimmed) **************** -->

  <Content
    tagline="The Challenge vs. The Future"
    title="Why Green NanoBiotech Solutions?"
    items={[
      {
        title: 'Traditional Chemical Inputs',
        description:
          'Chemical pesticides and fertilisers cause environmental harm, persist in soil and water, threaten biodiversity, and leave residues in food — posing serious long-term risks to ecosystems and public health.',
        icon: 'tabler:alert-triangle',
      },
      {
        title: 'Agricultural Waste, Rethought',
        description:
          'Australia generates over 30 million tonnes of agricultural by-products annually. Instead of burning or landfilling them, we unlock the high-value biopolymers, silica, and cellulose locked inside.',
        icon: 'tabler:wheat',
      },
      {
        title: 'Our Nano-Technology Platform',
        description:
          'Our proprietary synthesis platform engineers agricultural by-products into precision bio-based nano-carriers that deliver nutrients and crop protection deep into plant tissue. The result: stimulated root development, strengthened cell walls, and potent suppression of soil-borne pathogens - all produced through a zero-hazardous-waste process that closes the loop on farm waste.',
        icon: 'tabler:atom-2',
      },
    ]}
    image={{
      src: '~/assets/images/farm-from-top.png',
      alt: 'Farm from the top',
      width: 754,
      height: 500,
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2 text-center">
        A New Era of Agriculture
      </h3>
      <p class="text-center">
        Moving from hazardous broad-spectrum chemicals to safe, naturally-derived, induced-resistance solutions.
      </p>
      <div class="text-center mt-6">
        <Button variant="secondary" text="Explore the science behind our process" href="/our-science" icon="tabler:arrow-right" />
      </div>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Product Showcase **************** -->

  <section class="py-12 lg:py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="text-center mb-10">
        <p class="text-base font-semibold uppercase tracking-widest text-primary dark:text-blue-200">
          Product Portfolio
        </p>
        <h2 class="text-4xl font-bold tracking-tight dark:text-white sm:text-5xl mt-2">Tailored Nano-Biomaterials</h2>
        <p class="mt-4 text-xl text-muted dark:text-slate-400">
          From precision nutrition to pathogen control — engineered for Australian farms.
        </p>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          products.map((product) => (
            <a
              href={getPermalink(`/products/${product.id}`)}
              class="group flex flex-col rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-800 shadow-sm hover:shadow-lg transition-shadow duration-300 overflow-hidden"
            >
              <div class="flex items-center justify-center bg-blue-50 dark:bg-slate-700 p-5">
                <Image
                  src={product.data.image.src}
                  alt={product.data.image.alt}
                  width={120}
                  height={150}
                  objectFit="contain"
                  class="max-h-32"
                />
              </div>
              <div class="p-5">
                <h3 class="text-lg font-bold dark:text-white group-hover:text-primary transition-colors">
                  {product.data.name}
                </h3>
                <p class="text-sm text-muted dark:text-slate-400 mt-1">{product.data.subtitle}</p>
                <span class="mt-3 inline-flex items-center justify-center rounded-full border border-primary bg-primary px-5 py-2 text-sm font-semibold text-white group-hover:bg-secondary group-hover:border-secondary transition">
                  View details
                  <svg xmlns="http://www.w3.org/2000/svg" class="ml-1.5 w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </span>
              </div>
            </a>
          ))
        }
      </div>

      <div class="text-center mt-10">
        <Button variant="primary" text="Browse All Products" href="/products" icon="tabler:arrow-right" />
      </div>
    </div>
  </section>

  <!-- Research Highlights **************** -->

  <Features2
    tagline="Proven in Australian Soils"
    title="Data-Driven Results from Our Field Trials"
    subtitle="We don't ask farmers to operate on promises. Our nano-biomaterials are rigorously tested across Australian conditions."
    columns={3}
    callToAction={{ variant: 'secondary', text: 'See all R&D data and trial sites', href: '/research', icon: 'tabler:arrow-right' }}
    items={[
      {
        title: '30% Higher Nitrogen Efficiency',
        description:
          'Field trials on broadacre wheat showed crops uptake 30% more nitrogen before leaching when using our Nano-Primers alongside standard NPK.',
        icon: 'tabler:chart-bar',
      },
      {
        title: '95% Pathogen Suppression',
        description:
          'Horticulture trials against aggressive fungal rot showed over 95% reduction in infection rates compared to control groups.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Enhanced Drought Tolerance',
        description:
          'Treated crops extended their wilting point through consecutive 40°C+ summer days due to systemic immune priming.',
        icon: 'tabler:sun',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- About / Team Teaser **************** -->

  <Content
    isReversed
    tagline="Who We Are"
    title="Australian-Made, Research-Driven"
    items={[
      {
        title: 'Our Science',
        description:
          'Pioneering the transformation of agricultural by-products into high-performance green nano-biomaterials using environmentally friendly chemistry.',
        icon: 'tabler:microscope',
      },
      {
        title: 'Our Team',
        description:
          'Based in Melbourne, our co-founders bring deep expertise in green chemistry and materials science, backed by years of hands-on agronomic experience.',
        icon: 'tabler:users',
      },
      {
        title: 'Our Mission',
        description:
          'Close the loop on agricultural waste — empowering farmers with safe, effective, and sustainable nano-solutions that protect crops without harming the planet.',
        icon: 'tabler:leaf',
      },
    ]}
    image={{
      src: '~/assets/images/team.png',
      alt: 'Team in farm field',
      width: 733,
      height: 400,
      class: 'mx-auto rounded-md max-w-sm',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Innovation should serve the planet.
      </h3>
      <p>Reducing agricultural waste, promoting biodiversity, and enabling resilient farming practices.</p>
      <div class="mt-6">
        <Button variant="secondary" text="Meet the team and our goals" href="/our-goals" icon="tabler:arrow-right" />
      </div>
    </Fragment>
  </Content>

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Partner with Us',
        href: '/contact',
        icon: 'tabler:calendar-event',
      },
      {
        text: 'Meet the Leadership',
        href: '/leadership',
      },
    ]}
  >
    <Fragment slot="title">Ready to Grow Together?</Fragment>

    <Fragment slot="subtitle">
      We're actively seeking forward-thinking distributors, agronomists, and trial partners across Australia.
    </Fragment>
  </CallToAction>
</Layout>
