---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { Icon } from 'astro-icon/components';

const metadata = {
  title: 'Hoang Nhan NanoBiotech | Revolutionising Crop Yields',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Partner with Us',
        href: 'https://nanobiotech.com.au/contact',
        target: '_blank',
        icon: 'tabler:calendar-event',
      },
      { text: 'Discover Our Science', href: '/our-science' },
    ]}
    image={{
      src: '~/assets/images/bypro-plant-fruit.png',
      alt: 'The cycle from agricultural by-products to advanced green nano-biomaterials',
    }}
  >
    <Fragment slot="title">
      Revolutionising Crop Yields <br class="hidden md:inline" />
      &nbsp;
      <span class="text-primary dark:text-white highlight">through Circular Nanobiotech</span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="hidden sm:inline">
        Welcome to Hoang Nhan NanoBiotech, where innovation meets sustainability. Our mission is to enhance plant health
        and protection through eco-friendly solutions that harness the power of nanotechnology. We repurpose
        agricultural by-products into advanced green nano-biomaterials.</span
      >
    </Fragment>
  </Hero>

  <!-- Content Widget (Who We Are) **************** -->

  <Content
    isReversed
    tagline="Who We Are"
    title="Pioneers in Green Nano Biomaterials"
    items={[
      {
        title: 'Our Mission',
        description:
          'Founded on a commitment to green science, we blend rigorous research with practical applications to support farmers, agribusinesses, and ecosystems worldwide.',
        icon: 'tabler:check',
      },
      {
        title: 'Our Team',
        description:
          'Based in Melbourne, Victoria, we are a dynamic team of scientists, engineers, and visionaries passionate about sustainable agriculture and biotechnology.',
        icon: 'tabler:users',
      },
      {
        title: 'Our Approach',
        description:
          'We collaborate with academic institutions, industry partners, and farmers to ensure our work is grounded in real-world needs and ethical standards.',
        icon: 'tabler:microscope',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1542601906990-b4d3fb778b09?ixlib=rb-4.0.3&auto=format&fit=crop&w=2000&q=80',
      alt: 'Team holding plant sprouts',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Innovation should serve the planet.
      </h3>
      Reducing agricultural waste, promoting biodiversity, and enabling resilient farming practices.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget (Problem / Solution) **************** -->

  <Content
    tagline="The Challenge vs. The Future"
    title="Why Green NanoBiotech Solutions?"
    items={[
      {
        title: 'Traditional Chemical Inputs',
        description:
          '<ul class="list-disc ml-4 space-y-2">\n' +
          '  <li><strong>Environmental Harm:</strong> Chemical inputs cause significant ecological damage.</li>\n' +
          '  <li><strong>Reduced Efficacy:</strong> High leaching and low absorption limit agronomic effectiveness.</li>\n' +
          '  <li><strong>Persistence & Accumulation:</strong> Agrochemicals remain in soil and water, accumulating in the food chain.</li>\n' +
          '  <li><strong>Biodiversity Loss:</strong> Residues disrupt ecosystems and harm beneficial, non-target organisms.</li>\n' +
          '  <li><strong>Health Risks:</strong> Residues in food can induce genetic alterations and developmental abnormalities.</li>\n' +
          '  <li><strong>Global Threat:</strong> These impacts collectively threaten ecosystem stability, food safety, and public health.</li>\n' +
          '</ul>',
        icon: 'tabler:alert-triangle',
      },
      {
        title: 'Agricultural By-Products in Australia',
        description:
          '<ul class="list-disc ml-4 space-y-2">\n' +
          '  <li><strong>Massive Waste:</strong> Australia generates over 30 million tonnes of agricultural by-products (like rice hulls and sugarcane bagasse) every year. Combustion generates bagasse ash with over 230,000 tons annually.</li>\n' +
          '  <li><strong>Environmental Degradation:</strong> Current disposal practices, such as open burning and landfilling, cause severe air and water pollution.</li>\n' +
          '  <li><strong>Untapped Potential:</strong> These agricultural residues are incredibly rich in valuable biopolymers, cellulose, and high-purity silica, potassium and phosphorus.</li>\n' +
          '</ul>',
        icon: 'tabler:wheat',
      },
    ]}
    bottomImage={{
      src: '~/assets/images/modern-farm.png',
      alt: 'Modern farm with corn',
    }}
  >
    <Fragment slot="image">
      <div class="flex gap-3 items-start">
        <div
          class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-green-600 dark:bg-green-700 text-gray-50 p-1"
        >
          <Icon name="tabler:microscope" class="h-5 w-5" />
        </div>
        <div>
          <h4 class="text-lg font-medium leading-6 dark:text-white">HN NanoBiotech Solutions</h4>
          <ul class="list-disc ml-4 space-y-2 mt-2">
            <li>
              <strong>Advanced Nano-Synthesis:</strong> We conduct cutting-edge research to transform agricultural waste
              into high-value, high-tech green nano-biomaterials.
            </li>
            <li>
              <strong>Precision Bio-Carriers:</strong> Our state-of-the-art bio-based nano-carriers ensure systemic uptake
              and controlled release, delivering nutrients and protection precisely when crops need them.
            </li>
            <li>
              <strong>True Circular Economy:</strong> Our sophisticated synthesis process generates absolutely zero hazardous
              waste. Natural raw materials are fully repurposed into next-generation fertilizers and bio-nano formulations.
            </li>
            <li>
              <strong>Enhanced Immunity & Growth:</strong> Our highly engineered solutions actively stimulate robust root
              development, strengthen plant cell walls, and fortify natural resistance against environmental extremes.
            </li>
            <li>
              <strong>Targeted Pathogen Suppression:</strong> Highly effective at naturally and forcefully suppressing devastating
              plant pathogenic fungi and oomycetes, including <em>Pythium</em>, <em>Phytophthora</em>, <em>Fusarium</em
              >, and <em>Rhizoctonia</em>.
            </li>
          </ul>
        </div>
      </div>
    </Fragment>
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2 text-center">
        A New Era of Agriculture
      </h3>
      <p class="text-center">
        Moving from inefficient broad-spectrum hazardous chemicals to green, safe, naturally-derived, induced-resistance
        solutions.
      </p>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Features Widget (Key Pillars) *************** -->

  <Features
    id="pillars"
    tagline="Our Key Pillarsin
    title="The Foundation of HN NanoBiotech"
    subtitle="Built on science, driven by sustainability."
    items={[
      {
        title: 'Green Solution',
        description:
          'We develop truly green materials and deliver sustainable solutions that strengthen agricultural systems. By harnessing nanobiotechnology and circular principles, we create eco-friendly nano-biomaterials from agricultural by-products reducing waste, minimizing chemical inputs, and empowering healthier, more resilient crops.',
        icon: 'tabler:leaf',
      },
      {
        title: 'Sustainability',
        description:
          'We transform agricultural by-products into high-value green nanobiomaterials turning waste into a powerful ally for agriculture. These advanced materials reinforce plant defenses, providing effective protection against diseases, environmental stresses, and pests.',
        icon: 'tabler:recycle',
      },
      {
        title: 'Environmental Protection',
        description:
          'We are committed to closing the loop on agricultural waste. Through innovative valorisation, we transform abundant by-products into advanced green nanobiomaterials, turning what was once discarded into a powerful resource.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Crop Protection & Enhancement',
        description:
          'We empower plants to protect themselves earlier and more effectively. By strengthening natural immunity at the molecular level, our nanobiotechnology solutions help crops resist pests and diseases from the start and maintain strong, healthy growth.',
        icon: 'tabler:plant',
      },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Review our R&D',
        href: '/research',
        icon: 'tabler:microscope',
      },
    ]}
  >
    <Fragment slot="title"> Being proven in Australian Soils </Fragment>

    <Fragment slot="subtitle">
      Explore our interactive field trials and robust data validating our natural approach to crop enhancement.
    </Fragment>
  </CallToAction>
</Layout>
