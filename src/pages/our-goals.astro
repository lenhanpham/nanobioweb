---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Steps from '~/components/widgets/Steps.astro';
import Features from '~/components/widgets/Features.astro';
import Features3 from '~/components/widgets/Features3.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Our Goals | Hoang Nhan Nano Biotech',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="Our Goals"
    image={{
      src: '~/assets/images/team.png',
      alt: 'Team in farm field',
      width: 733,
      height: 400,
      class: 'mx-auto rounded-md max-w-sm',
    }}
  >
    <Fragment slot="title">
      Australian Made & <br />
      <span class="text-primary dark:text-white highlight"> Research-Driven</span>
    </Fragment>

    <Fragment slot="subtitle">
      Based in Melbourne, Victoria, we are a dynamic team of scientists, engineers, and visionaries passionate about
      sustainable agriculture and biotechnology. Our startup brings together expertise in nanotechnology, materials
      science, and environmental biology to develop breakthrough eco-friendly solutions.
    </Fragment>
  </Hero>

  <!-- Mission & Vision **************** -->

  <Steps
    title="Our Mission & Vision"
    subtitle="We exist to close the loop on agricultural waste — transforming abundant by-products into high-performance nano-biomaterials that protect crops, restore ecosystems, and empower Australian farmers."
    items={[
      {
        title: 'Waste to Value',
        description:
          'Our founders and researchers have years of experience in converting waste into value, drawing from abundant natural resources like sugarcane bagasse and rice husks to create high-performance biomaterials.',
      },
      {
        title: 'Collaborative Excellence',
        description:
          'We collaborate with academic institutions, industry partners, and farmers to ensure our work is grounded in real-world needs and ethical standards.',
      },
      {
        title: 'Empowering Farmers',
        description:
          "Technology is useless if it's too hard to use. Our nano-solutions are formulated to plug seamlessly into existing irrigation and spray setups without costly overhauls.",
      },
      {
        title: 'Regulatory Alignment',
        description:
          'We engage transparently with local authorities, building pathways aligned with Australian standards and paving the way for organic certifications.',
      },
    ]}
    image={{
      src: '~/assets/images/vision.png',
      alt: 'Vision',
    }}
    classes={{ image: 'mx-auto max-w-sm rounded-md shadow-lg' }}
  />

  <!-- Key Pillars **************** -->

  <Features
    tagline="Our Key Pillars"
    title="The Foundation of HN NanoBiotech"
    subtitle="Built on science, driven by sustainability."
    items={[
      {
        title: 'Green Solution',
        description:
          'We develop truly green materials and deliver sustainable solutions that strengthen agricultural systems. By harnessing nanobiotechnology and circular principles, we create eco-friendly nano-biomaterials from agricultural by-products — reducing waste, minimizing chemical inputs, and empowering healthier, more resilient crops.',
        icon: 'tabler:leaf',
      },
      {
        title: 'Sustainability',
        description:
          'We transform agricultural by-products into high-value green nanobiomaterials — turning waste into a powerful ally for agriculture. These advanced materials reinforce plant defenses, providing effective protection against diseases, environmental stresses, and pests.',
        icon: 'tabler:recycle',
      },
      {
        title: 'Environmental Protection',
        description:
          'We are committed to closing the loop on agricultural waste. Through innovative valorisation, we transform abundant by-products into advanced green nanobiomaterials, turning what was once discarded into a powerful resource.',
        icon: 'tabler:world',
      },
      {
        title: 'Crop Protection & Enhancement',
        description:
          'We empower plants to protect themselves earlier and more effectively. By strengthening natural immunity at the molecular level, our nanobiotechnology solutions help crops resist pests and diseases from the start and maintain strong, healthy growth.',
        icon: 'tabler:shield-check',
      },
    ]}
  />

  <!-- Field Driven **************** -->

  <Features3
    title="We Trust Muddy Boots Over Stock Photos"
    subtitle="Our science doesn't stop at a white coat. We spend our time in the dirt, talking to farmers, and understanding what actually moves the needle at harvest time."
    columns={1}
    items={[
      {
        title: 'Field Driven Data',
        description:
          'At our core, we are driven by a shared belief that innovation should serve the planet: reducing agricultural waste, promoting biodiversity, and enabling resilient farming practices across Australia and the world.',
        icon: 'tabler:tractor',
      },
    ]}
  />

  <!-- CTA **************** -->

  <CallToAction
    actions={[{ variant: 'primary', text: 'Partner with Us', href: '/contact' }]}
    title="Ready to Grow Together?"
    subtitle="We're actively seeking forward-thinking distributors, agronomists, and trial partners across Australia."
  />
</Layout>
